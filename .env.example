# ========================
# Environnement
# ========================
NODE_ENV=development

# ========================
# Serveur
# ========================
PORT=5000
HOST=localhost
CORS_ORIGIN=http://localhost:3000

# ========================
# Base de données (PostgreSQL) Neon
# ========================
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexusflow_dev?schema=public

# ========================
# JWT
# ========================
JWT_ACCESS_SECRET=change_me_to_a_random_secret
JWT_REFRESH_SECRET=change_me_to_another_random_secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ========================
# Email (SMTP)
# ========================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nexusflow.local

# ========================
# Uploads
# ========================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ========================
# Logs
# ========================
LOG_LEVEL=debug